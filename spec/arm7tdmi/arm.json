{
  "$schema": "../schema/cpu-spec.schema.json",
  "spec_version": "1.0",
  "name": "ARM",
  "width_bits": 32,
  "alignment_bytes": 4,
  "pc_offset_bytes": 8,
  "endian_within_word": "little",
  "global_condition": {
    "field": "31:28",
    "table": {
      "0000": "EQ",
      "0001": "NE",
      "0010": "CS",
      "0011": "CC",
      "0100": "MI",
      "0101": "PL",
      "0110": "VS",
      "0111": "VC",
      "1000": "HI",
      "1001": "LS",
      "1010": "GE",
      "1011": "LT",
      "1100": "GT",
      "1101": "LE",
      "1110": "AL",
      "1111": "NV"
    },
    "applies_to": "all_unless_marked_unconditional"
  },
  "decode_strategy": "mask_match_priority",
  "encoding_groups": [
    {
      "$include": "groups/branch-exchange.json"
    },
    {
      "$include": "groups/psr-transfer.json"
    },
    {
      "$include": "groups/multiply.json"
    },
    {
      "$include": "groups/multiply-long.json"
    },
    {
      "$include": "groups/data-processing.json"
    },
    {
      "$include": "groups/single-data-transfer.json"
    },
    {
      "$include": "groups/halfword-signed-data-transfer.json"
    },
    {
      "$include": "groups/single-data-swap.json"
    },
    {
      "$include": "groups/block-data-transfer.json"
    },
    {
      "$include": "groups/branch.json"
    },
    {
      "$include": "groups/coprocessor.json"
    },
    {
      "$include": "groups/software-interrupt.json"
    },
    {
      "$include": "groups/architecturally-undefined.json"
    }
  ]
}