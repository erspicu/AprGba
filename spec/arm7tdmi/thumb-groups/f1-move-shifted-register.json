                { "op": "lsr", "in": ["rs_val", "shamt_inv"], "out": "carry_raw" },
                { "op": "and", "in": ["carry_raw", { "const": 1 }], "out": "shifter_carry_out" },
                { "op": "update_c_shifter", "in": ["shifter_carry_out"] }
              ]
            }
          ]
        },
        {
          "selector": {
            "field": "op",
            "value": "01"
          },
          "mnemonic": "LSR",
          "since": "ARMv4T",
          "writes_pc": "never",
          "cycles": {
            "form": "1S"
          },
          "steps": [
            { "op": "read_reg", "index": "rs", "out": "rs_val" },
            { "op": "select",
              "cond": { "field": "imm5", "eq": 0 },
              "if_true":  { "const": 32 },
              "if_false": "imm5",
              "out": "amount" },
            { "op": "lsr_with_c", "in": ["rs_val", "amount"], "out": "result" },
            { "op": "write_reg", "index": "rd", "value": "result" },
            { "op": "update_nz", "value": "result" }
          ]
        },
