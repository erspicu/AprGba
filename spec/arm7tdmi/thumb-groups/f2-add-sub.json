          "comment":    "SUB Rd, Rs, #imm3",
          "cycles":     { "form": "1S" },
          "steps": [
            { "op": "read_reg", "index": "rs", "out": "rs_val" },
            { "op": "sub", "in": ["rs_val", "rn_or_imm3"], "out": "result" },
