{
  "$schema": "../schema/cpu-spec.schema.json",
  "spec_version": "1.0",
  "name": "Thumb",
  "width_bits": 16,
  "alignment_bytes": 2,
  "pc_offset_bytes": 4,
  "endian_within_word": "little",
  "$comment_no_global_condition": "Thumb-1 has no per-instruction condition field; only Branch (Format 16) carries a 4-bit cond.",
  "decode_strategy": "mask_match_priority",
  "encoding_groups": [
    { "$include": "thumb-groups/f2-add-sub.json" },
    { "$include": "thumb-groups/f1-move-shifted-register.json" },
    { "$include": "thumb-groups/f3-mov-cmp-add-sub-imm.json" },
    { "$include": "thumb-groups/f4-alu-ops.json" },
    { "$include": "thumb-groups/f5-hi-register-ops.json" },
    { "$include": "thumb-groups/f6-pc-relative-load.json" },
    { "$include": "thumb-groups/f7-load-store-reg-offset.json" },
    { "$include": "thumb-groups/f8-sign-extended.json" },
    { "$include": "thumb-groups/f9-load-store-imm-offset.json" },
    { "$include": "thumb-groups/f10-load-store-halfword.json" },
    { "$include": "thumb-groups/f11-sp-relative.json" },
    { "$include": "thumb-groups/f18-unconditional-branch.json" }
  ]
}