{
  "$schema": "../schema/cpu-spec.schema.json",
  "spec_version": "1.0",
  "name": "Thumb",
  "width_bits": 16,
  "alignment_bytes": 2,
  "pc_offset_bytes": 4,
  "endian_within_word": "little",
  "$comment_no_global_condition": "Thumb-1 has no per-instruction condition field; only Branch (Format 16) carries a 4-bit cond.",
  "decode_strategy": "mask_match_priority",
  "encoding_groups": [
    {
      "$include": "thumb-groups/f1-move-shifted-register.json"
    },
    {
      "$include": "thumb-groups/f3-mov-cmp-add-sub-imm.json"
    },
    {
      "$include": "thumb-groups/f18-unconditional-branch.json"
    }
  ]
}