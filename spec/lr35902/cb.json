{
  "$schema": "../schema/cpu-spec.schema.json",
  "spec_version": "1.0",
  "name": "CB",
  "width_bits": 8,
  "alignment_bytes": 1,
  "pc_offset_bytes": 1,
  "endian_within_word": "little",
  "decode_strategy": "mask_match_priority",
  "encoding_groups": [
    { "$include": "groups/cb-prefix-shift.json" },
    { "$include": "groups/cb-prefix-bit.json" },
    { "$include": "groups/cb-prefix-res.json" },
    { "$include": "groups/cb-prefix-set.json" }
  ]
}
