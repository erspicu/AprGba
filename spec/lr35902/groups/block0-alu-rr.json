{
  "name": "Block0_AluRr",
  "comment": "16-bit operations on register pairs: INC rr (00_dd0_011), DEC rr (00_dd1_011), ADD HL,rr (00_dd1_001). 12 opcodes total. INC/DEC rr don't affect any flags (migrated to per-dd selector variants of the named-pair add/sub chain). ADD HL,rr stays on the LR35902-specific lr35902_add_hl_rr emitter — the H/C flags come off bits 11/15 of the 16-bit add and need arch-specific helpers.",
  "formats": [
    {
      "name": "Inc_Rr",
      "comment": "00_dd0_011 — INC rr. dd: 00=BC, 01=DE, 10=HL, 11=SP. No flag effects.",
      "pattern": "00dd0011",
      "fields": { "dd": "5:4" },
      "mask": "0xCF",
      "match": "0x03",
      "instructions": [
        { "selector": { "field": "dd", "value": "00" }, "mnemonic": "INC", "since": "LR35902", "manual_ref": "GB CPU §INC BC", "cycles": { "form": "2m" }, "steps": [{ "op": "read_reg_pair_named", "name": "BC", "out": "v" }, { "op": "add", "in": ["v", { "const": 1 }], "out": "v_new" }, { "op": "write_reg_pair_named", "name": "BC", "value": "v_new" }] },
        { "selector": { "field": "dd", "value": "01" }, "mnemonic": "INC", "since": "LR35902", "manual_ref": "GB CPU §INC DE", "cycles": { "form": "2m" }, "steps": [{ "op": "read_reg_pair_named", "name": "DE", "out": "v" }, { "op": "add", "in": ["v", { "const": 1 }], "out": "v_new" }, { "op": "write_reg_pair_named", "name": "DE", "value": "v_new" }] },
        { "selector": { "field": "dd", "value": "10" }, "mnemonic": "INC", "since": "LR35902", "manual_ref": "GB CPU §INC HL", "cycles": { "form": "2m" }, "steps": [{ "op": "read_reg_pair_named", "name": "HL", "out": "v" }, { "op": "add", "in": ["v", { "const": 1 }], "out": "v_new" }, { "op": "write_reg_pair_named", "name": "HL", "value": "v_new" }] },
        { "selector": { "field": "dd", "value": "11" }, "mnemonic": "INC", "since": "LR35902", "manual_ref": "GB CPU §INC SP", "cycles": { "form": "2m" }, "steps": [{ "op": "read_reg_pair_named", "name": "SP", "out": "v" }, { "op": "add", "in": ["v", { "const": 1 }], "out": "v_new" }, { "op": "write_reg_pair_named", "name": "SP", "value": "v_new" }] }
      ]
    },
    {
