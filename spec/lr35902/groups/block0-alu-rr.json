        { "selector": { "field": "dd", "value": "01" }, "mnemonic": "DEC", "since": "LR35902", "manual_ref": "GB CPU §DEC DE", "cycles": { "form": "2m" }, "steps": [{ "op": "read_reg_pair_named", "name": "DE", "out": "v" }, { "op": "sub", "in": ["v", { "const": 1 }], "out": "v_new" }, { "op": "write_reg_pair_named", "name": "DE", "value": "v_new" }] },
