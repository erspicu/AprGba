{
  "name": "Block0_MemIndirect",
  "comment": "LD via register-pair pointer with auto-increment/decrement on HL: 8 opcodes total. Pattern: 00_pps_010, where pp selects BC/DE/HL+/HL- and s=0 stores A→memory, s=1 loads memory→A.",
  "formats": [
    {
      "name": "LdInd_BC_A",
      "comment": "0x02 — LD (BC), A",
      "pattern": "00000010",
      "fields": {},
      "mask": "0xFF",
      "match": "0x02",
      "instructions": [{
        "mnemonic": "LD", "since": "LR35902", "manual_ref": "GB CPU §LD (BC),A",
        "writes_memory": ["A"], "cycles": { "form": "2m" },
        "steps": [
          { "op": "read_reg_pair_named", "name": "BC", "out": "addr" },
          { "op": "read_reg_named", "name": "A", "out": "v" },
          { "op": "store_byte", "address": "addr", "value": "v" }
        ]
      }]
    },
    {
      "name": "LdInd_DE_A",
      "comment": "0x12 — LD (DE), A",
      "pattern": "00010010",
      "fields": {},
      "mask": "0xFF",
      "match": "0x12",
      "instructions": [{
        "mnemonic": "LD", "since": "LR35902", "manual_ref": "GB CPU §LD (DE),A",
        "writes_memory": ["A"], "cycles": { "form": "2m" },
        "steps": [
          { "op": "read_reg_pair_named", "name": "DE", "out": "addr" },
          { "op": "read_reg_named", "name": "A", "out": "v" },
          { "op": "store_byte", "address": "addr", "value": "v" }
        ]
      }]
    },
    {
      "name": "LdInd_HLi_A",
      "comment": "0x22 — LD (HL+), A (post-increment HL)",
      "pattern": "00100010",
      "fields": {},
      "mask": "0xFF",
      "match": "0x22",
      "instructions": [{
        "mnemonic": "LDI", "since": "LR35902", "manual_ref": "GB CPU §LD (HL+),A",
        "writes_memory": ["A"], "cycles": { "form": "2m" },
        "steps": [
          { "op": "read_reg_pair_named", "name": "HL", "out": "addr" },
          { "op": "read_reg_named", "name": "A", "out": "v" },
          { "op": "store_byte", "address": "addr", "value": "v" },
          { "op": "read_reg_pair_named",  "name": "HL", "out": "hl_pre" },
          { "op": "add",                   "in": ["hl_pre", { "const": 1 }], "out": "hl_new" },
          { "op": "write_reg_pair_named",  "name": "HL", "value": "hl_new" }
        ]
      }]
    },
    {
      "name": "LdInd_HLd_A",
