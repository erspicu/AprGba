{
  "name": "Block0_MiscControl",
  "comment": "Standalone block 0 opcodes that don't fit any encoding family: NOP/STOP plus the 'col 7' rotate/decimal-adjust/flag-twiddle group (00_xxx_111). Every opcode listed individually with mask 0xFF for clarity — these are control-flow misc, not a regular grid.",
  "formats": [
    {
      "name": "Nop",
      "comment": "0x00 — NOP",
      "pattern": "00000000",
      "fields": {},
      "mask": "0xFF",
      "match": "0x00",
      "instructions": [{
        "mnemonic": "NOP", "since": "LR35902", "manual_ref": "GB CPU §NOP",
        "cycles": { "form": "1m" },
        "steps": []
      }]
    },
    {
      "name": "Stop",
      "comment": "0x10 — STOP. Officially a 2-byte instruction (0x10 0x00) but DMG ignores the trailing byte and PC advances by 1, matching LegacyCpu / AprGBemu reference behaviour. Treating STOP as halting until IRQ is the conservative correct semantic for non-CGB.",
      "pattern": "00010000",
      "fields": {},
      "mask": "0xFF",
      "match": "0x10",
      "instructions": [{
        "mnemonic": "STOP", "since": "LR35902", "manual_ref": "GB CPU §STOP",
        "cycles": { "form": "1m" },
        "steps": []
      }]
    },
    {
      "name": "Rlca",
      "comment": "0x07 — RLCA. Like CB-prefix RLC A but always clears Z (rather than setting it on zero result). Generic shift kind=rlc with N/H/C updates; Z forced to 0 by an explicit set_flag (we omit flag_z so the shift op leaves Z untouched).",
      "pattern": "00000111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x07",
      "instructions": [{
        "mnemonic": "RLCA", "since": "LR35902", "manual_ref": "GB CPU §RLCA",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "read_reg_named",  "name": "A", "out": "v" },
          { "op": "shift",           "kind": "rlc", "in": "v", "out": "w", "reg": "F", "flag_n": "N", "flag_h": "H", "flag_c": "C" },
          { "op": "set_flag",        "reg": "F", "flag": "Z", "value": 0 },
          { "op": "write_reg_named", "name": "A", "value": "w" }
        ]
      }]
    },
    {
      "name": "Rrca",
      "comment": "0x0F — RRCA. Z always cleared. See Rlca comment for the kind=rrc / Z=0 split.",
      "pattern": "00001111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x0F",
      "instructions": [{
        "mnemonic": "RRCA", "since": "LR35902", "manual_ref": "GB CPU §RRCA",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "read_reg_named",  "name": "A", "out": "v" },
          { "op": "shift",           "kind": "rrc", "in": "v", "out": "w", "reg": "F", "flag_n": "N", "flag_h": "H", "flag_c": "C" },
          { "op": "set_flag",        "reg": "F", "flag": "Z", "value": 0 },
          { "op": "write_reg_named", "name": "A", "value": "w" }
        ]
      }]
    },
    {
      "name": "Rla",
      "comment": "0x17 — RLA. Z always cleared; rotates through C. kind=rl reads C from F as the input bit then writes back the new C.",
      "pattern": "00010111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x17",
      "instructions": [{
        "mnemonic": "RLA", "since": "LR35902", "manual_ref": "GB CPU §RLA",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "read_reg_named",  "name": "A", "out": "v" },
          { "op": "shift",           "kind": "rl", "in": "v", "out": "w", "reg": "F", "flag_n": "N", "flag_h": "H", "flag_c": "C" },
          { "op": "set_flag",        "reg": "F", "flag": "Z", "value": 0 },
          { "op": "write_reg_named", "name": "A", "value": "w" }
        ]
      }]
    },
    {
      "name": "Rra",
      "comment": "0x1F — RRA. Z always cleared; rotates through C.",
      "pattern": "00011111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x1F",
      "instructions": [{
        "mnemonic": "RRA", "since": "LR35902", "manual_ref": "GB CPU §RRA",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "read_reg_named",  "name": "A", "out": "v" },
          { "op": "shift",           "kind": "rr", "in": "v", "out": "w", "reg": "F", "flag_n": "N", "flag_h": "H", "flag_c": "C" },
          { "op": "set_flag",        "reg": "F", "flag": "Z", "value": 0 },
          { "op": "write_reg_named", "name": "A", "value": "w" }
        ]
      }]
    },
    {
      "name": "Daa",
      "comment": "0x27 — DAA. Decimal-adjust A after BCD arithmetic; flag semantics depend on N flag from the previous op.",
      "pattern": "00100111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x27",
      "instructions": [{
        "mnemonic": "DAA", "since": "LR35902", "manual_ref": "GB CPU §DAA",
        "cycles": { "form": "1m" },
        "steps": [{ "op": "lr35902_daa" }]
      }]
    },
    {
      "name": "Cpl",
      "comment": "0x2F — CPL. A ← ~A; sets N=H=1, Z/C unchanged. Lowered to generic ops: read A → mvn → write A → 2× set_flag.",
      "pattern": "00101111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x2F",
      "instructions": [{
        "mnemonic": "CPL", "since": "LR35902", "manual_ref": "GB CPU §CPL",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "read_reg_named",  "name": "A", "out": "a" },
          { "op": "mvn",             "in": ["a"], "out": "a_inv" },
          { "op": "write_reg_named", "name": "A", "value": "a_inv" },
          { "op": "set_flag",        "reg": "F", "flag": "N", "value": 1 },
          { "op": "set_flag",        "reg": "F", "flag": "H", "value": 1 }
        ]
      }]
    },
    {
      "name": "Scf",
      "comment": "0x37 — SCF. C←1, N=H=0, Z unchanged.",
      "pattern": "00110111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x37",
      "instructions": [{
        "mnemonic": "SCF", "since": "LR35902", "manual_ref": "GB CPU §SCF",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "set_flag", "reg": "F", "flag": "N", "value": 0 },
          { "op": "set_flag", "reg": "F", "flag": "H", "value": 0 },
          { "op": "set_flag", "reg": "F", "flag": "C", "value": 1 }
        ]
      }]
    },
    {
      "name": "Ccf",
      "comment": "0x3F — CCF. C←!C, N=H=0, Z unchanged. Lowered to generic ops: toggle_flag(C) + 2× set_flag.",
      "pattern": "00111111",
      "fields": {},
      "mask": "0xFF",
      "match": "0x3F",
      "instructions": [{
        "mnemonic": "CCF", "since": "LR35902", "manual_ref": "GB CPU §CCF",
        "cycles": { "form": "1m" },
        "steps": [
          { "op": "toggle_flag", "reg": "F", "flag": "C" },
          { "op": "set_flag",    "reg": "F", "flag": "N", "value": 0 },
          { "op": "set_flag",    "reg": "F", "flag": "H", "value": 0 }
        ]
      }]
    }
  ]
}
