        { "selector": { "field": "ooo", "value": "111" }, "mnemonic": "CP",  "since": "LR35902", "manual_ref": "GB CPU §CP r",    "cycles": { "form": "1m" }, "steps": [{ "op": "lr35902_alu_a_r8", "alu_op": "cp",  "field": "sss" }] }
