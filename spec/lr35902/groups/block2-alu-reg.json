        "sss": "2:0"
      },
      "mask": "0xC0",
      "match": "0x80",
      "instructions": [
        { "selector": { "field": "ooo", "value": "000" }, "mnemonic": "ADD", "since": "LR35902", "manual_ref": "GB CPU §ADD A,r", "cycles": { "form": "1m" }, "steps": [{ "op": "lr35902_alu_a_r8", "alu_op": "add", "field": "sss" }] },
