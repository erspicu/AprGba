        { "selector": { "field": "cc", "value": "01" }, "mnemonic": "CALL", "since": "LR35902", "manual_ref": "GB CPU §CALL Z,nn",  "writes_pc": "conditional", "cycles": { "form": "3m_or_6m" }, "steps": [{ "op": "read_imm16", "out": "target" }, { "op": "call_cc", "target": "target", "cond": { "reg": "F", "flag": "Z", "value": 1 } }] },
        { "selector": { "field": "cc", "value": "10" }, "mnemonic": "CALL", "since": "LR35902", "manual_ref": "GB CPU §CALL NC,nn", "writes_pc": "conditional", "cycles": { "form": "3m_or_6m" }, "steps": [{ "op": "read_imm16", "out": "target" }, { "op": "call_cc", "target": "target", "cond": { "reg": "F", "flag": "C", "value": 0 } }] },
        { "selector": { "field": "cc", "value": "11" }, "mnemonic": "CALL", "since": "LR35902", "manual_ref": "GB CPU §CALL C,nn",  "writes_pc": "conditional", "cycles": { "form": "3m_or_6m" }, "steps": [{ "op": "read_imm16", "out": "target" }, { "op": "call_cc", "target": "target", "cond": { "reg": "F", "flag": "C", "value": 1 } }] }
      ]
