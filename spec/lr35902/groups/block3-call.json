{
  "name": "Block3_Call",
  "comment": "Subroutine calls: CALL nn (0xCD) + 4 conditional CALL cc, nn variants. 5 opcodes total. CALL nn uses generic `call`; CALL cc nn uses generic `call_cc` with inline cond { reg, flag, value } so the cc-field becomes 4 selector variants.",
  "formats": [
    {
      "name": "Call_Nn",
      "comment": "0xCD — unconditional CALL nn",
      "pattern": "11001101",
      "fields": {},
      "mask": "0xFF",
      "match": "0xCD",
      "instructions": [{
        "mnemonic": "CALL", "since": "LR35902", "manual_ref": "GB CPU §CALL nn",
        "writes_pc": "always",
        "writes_memory": ["return_pc_lo", "return_pc_hi"],
        "cycles": { "form": "6m" },
        "steps": [
          { "op": "read_imm16", "out": "target" },
          { "op": "call",       "target":  "target" }
        ]
      }]
    },
    {
      "name": "Call_Cc_Nn",
